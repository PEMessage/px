#!/usr/bin/env python3
"""
px - 代理环境变量设置工具

架构:
    - Proxy: 仅保留 scheme 和 url_prefix
    - 各 Mode 自己管理变量名映射
    - 基类统一 dispatch set/unset 到独立方法
    - 接口返回 str 而非 list[str]，各 Mode 自己格式化
    - Mode 可有子参数解析（如 systemd 的 service 和 mode）
"""

from __future__ import annotations

import argparse
import subprocess
import sys
from abc import ABC, abstractmethod
from dataclasses import dataclass
from typing import Optional, Type, Sequence


# =============================================================================
# Data Models
# =============================================================================

@dataclass(frozen=True)
class Proxy:
    """代理配置数据模型 - 仅保留 scheme 和 url_prefix"""
    scheme: str         # http, https, socks5h
    url_prefix: str     # http://, socks5h://

    def full_url(self, host: str, port: str) -> str:
        return f"{self.url_prefix}{host}:{port}"


@dataclass
class ProxyList:
    """代理列表"""
    proxies: list[Proxy]
    host: str = ""
    port: str = ""

    def active(self, action: str) -> list[Proxy]:
        if action == "unset":
            return self.proxies
        if self.host and self.port:
            return self.proxies
        return []


# 默认代理定义
DEFAULT_PROXIES = ProxyList([
    Proxy("http", "http://"),
    Proxy("https", "http://"),
    Proxy("socks5h", "socks5h://"),
])


# =============================================================================
# Output Modes
# =============================================================================

class Mode(ABC):
    """
    输出模式的抽象基类
    
    子类实现:
        - _eval_set / _eval_unset: eval 子命令的具体实现
        - _echo_set / _echo_unset: echo 子命令的具体实现
    
    可选:
        - get_parser(): 返回子参数解析器（用于 mode 特有参数如 service, mode）
    
    基类 dispatch:
        - eval(action) -> 调用 _eval_set 或 _eval_unset
        - echo(action) -> 调用 _echo_set 或 _echo_unset
        
    返回字符串（可包含多行），各 Mode 自己格式化
    """
    NAME: str = ""
    SUPPORTED_SCHEMES: set[str] = set()

    def __init__(self, proxy_list: ProxyList, extra_args: list[str]):
        self.proxy_list = proxy_list
        self.extra_args = extra_args
        self._post_init()

    def _post_init(self):
        """子类可以重写此方法进行初始化"""
        pass

    @classmethod
    def get_parser(cls) -> Optional[argparse.ArgumentParser]:
        """
        可选: 返回子参数解析器
        用于 mode 特有参数（如 systemd 的 service 和 mode）
        返回 None 表示不需要子参数
        """
        return None

    def supports(self, scheme: str) -> bool:
        return scheme in self.SUPPORTED_SCHEMES

    def active_proxies(self, action: str) -> list[Proxy]:
        return [p for p in self.proxy_list.active(action) if self.supports(p.scheme)]

    # -------------------------------------------------------------------------
    # Dispatch methods
    # -------------------------------------------------------------------------
    def eval(self, action: str) -> str:
        """生成需要 eval 执行的命令 - dispatch 到具体方法"""
        if action == "set":
            return self._eval_set()
        else:  # unset
            return self._eval_unset()

    def echo(self, action: str) -> str:
        """生成直接输出的内容 - dispatch 到具体方法"""
        if action == "set":
            return self._echo_set()
        else:  # unset
            return self._echo_unset()

    # -------------------------------------------------------------------------
    # Abstract methods for subclasses to implement
    # -------------------------------------------------------------------------
    @abstractmethod
    def _eval_set(self) -> str:
        """eval set 的具体实现"""
        return ""

    @abstractmethod
    def _eval_unset(self) -> str:
        """eval unset 的具体实现"""
        return ""

    @abstractmethod
    def _echo_set(self) -> str:
        """echo set 的具体实现"""
        return ""

    @abstractmethod
    def _echo_unset(self) -> str:
        """echo unset 的具体实现"""
        return ""


class ShellMode(Mode):
    """Shell 环境变量模式 - 同时设置小写和大写变量"""
    NAME = "shell"
    SUPPORTED_SCHEMES = {"http", "https", "socks5h"}

    # 变量名映射: scheme -> (小写变量名, 大写变量名)
    VAR_MAP = {
        "http": ("http_proxy", "HTTP_PROXY"),
        "https": ("https_proxy", "HTTPS_PROXY"),
        "socks5h": ("socks5h_proxy", "SOCKS5H_PROXY"),
    }

    def _eval_set(self) -> str:
        lines = []
        for proxy in self.active_proxies("set"):
            var_names = self.VAR_MAP.get(proxy.scheme)
            if not var_names:
                continue
            url = proxy.full_url(self.proxy_list.host, self.proxy_list.port)
            for var_name in var_names:
                lines.append(f'export {var_name}="{url}"')
        return "\n".join(lines)

    def _eval_unset(self) -> str:
        lines = []
        for proxy in self.active_proxies("unset"):
            var_names = self.VAR_MAP.get(proxy.scheme)
            if not var_names:
                continue
            for var_name in var_names:
                lines.append(f"unset {var_name}")
        return "\n".join(lines)

    def _echo_set(self) -> str:
        """echo set 输出与 eval set 相同，方便用户预览"""
        return self._eval_set()

    def _echo_unset(self) -> str:
        """echo unset 输出与 eval unset 相同"""
        return self._eval_unset()


class NpmMode(ShellMode):
    """NPM 环境变量模式 - 继承 ShellMode，只覆盖 VAR_MAP"""
    NAME = "npm"
    SUPPORTED_SCHEMES = {"http", "https"}

    # 覆盖父类的 VAR_MAP (使用 tuple 单元素保持接口一致)
    VAR_MAP = {
        "http": ("npm_config_proxy",),
        "https": ("npm_config_https_proxy",),
    }


class GradleMode(Mode):
    """Gradle 配置模式"""
    NAME = "gradle"
    SUPPORTED_SCHEMES = {"http", "https", "socks5h"}

    # scheme 映射: 将 socks5h 映射为 gradle 使用的 "sock"
    GRADLE_SCHEME_MAP = {
        "http": "http",
        "https": "https",
        "socks5h": "sock",
    }

    def _eval_set(self) -> str:
        return ""

    def _eval_unset(self) -> str:
        return ""

    def _echo_set(self) -> str:
        lines = ["# 将以下内容添加到 gradle.properties:"]
        for proxy in self.active_proxies("set"):
            gradle_scheme = self.GRADLE_SCHEME_MAP.get(proxy.scheme, proxy.scheme)
            lines.append(f"systemProp.{gradle_scheme}.proxyHost={self.proxy_list.host}")
            lines.append(f"systemProp.{gradle_scheme}.proxyPort={self.proxy_list.port}")
        return "\n".join(lines)

    def _echo_unset(self) -> str:
        return ""


class SystemdMode(Mode):
    """Systemd 服务配置模式"""
    NAME = "systemd"
    SUPPORTED_SCHEMES = {"http", "https", "socks5h"}

    # 变量名映射: scheme -> (小写变量名, 大写变量名)
    VAR_MAP = {
        "http": ("http_proxy", "HTTP_PROXY"),
        "https": ("https_proxy", "HTTPS_PROXY"),
        "socks5h": ("socks5h_proxy", "SOCKS5H_PROXY"),
    }

    def __init__(self, proxy_list: ProxyList, extra_args: list[str]):
        # 先调用父类初始化
        super().__init__(proxy_list, extra_args)

    def _post_init(self):
        """解析 service 和 mode"""
        self.service = "docker.service"
        self.mode = "system"  # system 或 user

        for arg in self.extra_args:
            if arg in ("system", "user"):
                self.mode = arg
            else:
                self.service = arg

    @classmethod
    def get_parser(cls) -> argparse.ArgumentParser:
        """Systemd 特有参数解析器"""
        parser = argparse.ArgumentParser(prog='px -m systemd', add_help=False)
        parser.add_argument("service", nargs="?", default="docker.service",
                          help="服务名称 (默认: docker.service)")
        parser.add_argument("mode", nargs="?", choices=["system", "user"], default="system",
                          help="systemd 模式: system 或 user (默认: system)")
        return parser

    def _eval_set(self) -> str:
        return ""

    def _eval_unset(self) -> str:
        return ""

    def _echo_set(self) -> str:
        lines = []
        if self.mode == "system":
            lines.append(f"sudo systemctl daemon-reload")
            lines.append(f"sudo systemctl restart {self.service}")

            for proxy in self.active_proxies("set"):
                url = proxy.full_url(self.proxy_list.host, self.proxy_list.port)
                var_names = self.VAR_MAP.get(proxy.scheme, ())
                for var_name in var_names:
                    lines.append(f'echo \'Environment="{var_name}={url}"\' | sudo tee -a /run/systemd/system/{self.service}.d/override.conf')
        else:
            # user mode
            lines.append(f"mkdir -p $HOME/.config/systemd/user/{self.service}.d")
            lines.append(f"$EDITOR $HOME/.config/systemd/user/{self.service}.d/override.conf")
            lines.append("[Service]")

            for proxy in self.active_proxies("set"):
                url = proxy.full_url(self.proxy_list.host, self.proxy_list.port)
                var_names = self.VAR_MAP.get(proxy.scheme, ())
                for var_name in var_names:
                    lines.append(f'Environment="{var_name}={url}"')
        return "\n".join(lines)

    def _echo_unset(self) -> str:
        lines = []
        if self.mode == "system":
            for proxy in self.active_proxies("unset"):
                var_names = self.VAR_MAP.get(proxy.scheme, ())
                for var_name in var_names:
                    lines.append(f'sudo sed -i \'/Environment="{var_name}=/d\' /run/systemd/system/{self.service}.d/override.conf')
        return "\n".join(lines)


# =============================================================================
# Registry
# =============================================================================

MODES: dict[str, Type[Mode]] = {
    m.NAME: m for m in [ShellMode, GradleMode, NpmMode, SystemdMode]
}


# =============================================================================
# WSL Detection
# =============================================================================

def detect_wsl_ip() -> Optional[str]:
    """检测 WSL2 宿主机 IP"""
    try:
        r = subprocess.run(["wslinfo", "--networking-mode"], capture_output=True, text=True, timeout=2)
        if r.returncode == 0 and r.stdout.strip() == "mirrored":
            return "localhost"
    except:
        pass

    try:
        r = subprocess.run(["uname", "-a"], capture_output=True, text=True, timeout=2)
        if "wsl2" in r.stdout.lower():
            r = subprocess.run(["ip", "route", "show"], capture_output=True, text=True, timeout=2)
            for line in r.stdout.split("\n"):
                if "default" in line:
                    parts = line.split()
                    for i, p in enumerate(parts):
                        if p == "via" and i + 1 < len(parts):
                            return parts[i + 1]
    except:
        pass
    return None


# =============================================================================
# CLI
# =============================================================================

class HelpOnErrorParser(argparse.ArgumentParser):
    """自定义 ArgumentParser，help 输出返回 exit 2 而不是 0"""
    def print_help(self, file=None):
        super().print_help(file)
        sys.exit(2)  # 使用非零 exit code，防止 shell 包装层 eval

    def error(self, message):
        # 错误时也输出 help 并 exit 2
        self.print_usage(sys.stderr)
        self.exit(2, f'{self.prog}: error: {message}\n')


def parse_mode_args(mode_class: Type[Mode], extra_args: list[str]) -> tuple[list[str], bool]:
    """
    解析 mode 特有参数
    
    返回: (解析后的参数列表, 是否显示了 help)
    """
    parser = mode_class.get_parser()
    if parser is None:
        return extra_args, False
    
    # 检查是否有 -h 或 --help
    if '-h' in extra_args or '--help' in extra_args:
        parser.print_help()
        return [], True
    
    try:
        args = parser.parse_args(extra_args)
        # 将解析后的参数展平为列表
        result = []
        if hasattr(args, 'service'):
            result.append(args.service)
        if hasattr(args, 'mode'):
            result.append(args.mode)
        return result, False
    except SystemExit:
        # 解析失败，返回原始参数
        return extra_args, False


def main():
    # 先只解析 mode，避免 -h 被立即处理
    pre_parser = argparse.ArgumentParser(add_help=False)
    pre_parser.add_argument("-m", "--mode", choices=list(MODES.keys()), default="shell")
    
    # 分离出 mode 参数和剩余参数
    pre_args, remaining = pre_parser.parse_known_args()
    mode_class = MODES[pre_args.mode]
    
    # 检查是否是 mode 特有 help
    if '-h' in remaining or '--help' in remaining:
        mode_parser = mode_class.get_parser()
        if mode_parser:
            # 显示 mode 特有 help
            mode_parser.print_help()
            sys.exit(2)
    
    # 正常解析所有参数
    parser = HelpOnErrorParser(description="代理环境变量设置工具")
    parser.add_argument("cmd", choices=["eval", "echo"], help="子命令: eval 或 echo")
    parser.add_argument("-a", "--action", choices=["set", "unset"], required=True)
    parser.add_argument("-m", "--mode", choices=list(MODES.keys()), default="shell")
    parser.add_argument("-i", "--ip", help="代理服务器 IP (未设置则自动检测)")
    parser.add_argument("-p", "--port", default="7890", help="代理端口 (默认: 7890)")

    args, extra = parser.parse_known_args()
    
    # 获取选中的 mode 类（可能用户通过 -m 指定了不同的）
    mode_class = MODES[args.mode]
    
    # 如果 mode 有子参数解析器，解析其特有参数
    if mode_class.get_parser():
        extra, showed_help = parse_mode_args(mode_class, extra)
        if showed_help:
            sys.exit(2)  # help 显示后退出，非零 exit code

    # IP 未设置则自动检测
    host = args.ip
    if not host:
        host = detect_wsl_ip()
        if not host:
            print("# 警告: 无法检测 WSL IP，使用 localhost", file=sys.stderr)
            host = "localhost"

    if args.action == "set" and not host:
        print("错误: 无法获取代理 IP", file=sys.stderr)
        sys.exit(1)

    # 准备代理列表
    proxies = ProxyList(list(DEFAULT_PROXIES.proxies), host, args.port)

    # 创建 Mode
    mode = mode_class(proxies, extra)

    # 执行子命令 - dispatch 在 Mode 基类中完成
    if args.cmd == "eval":
        output = mode.eval(args.action)
    else:  # echo
        output = mode.echo(args.action)

    # 输出结果（可能是多行字符串）
    if output:
        print(output)


if __name__ == "__main__":
    main()
