#!/usr/bin/env python3
"""
px - 代理环境变量设置工具

一个 Pythonic 的代理环境变量管理工具，支持多种输出模式。

## 架构

- **Data Model**: `Proxy` (frozen dataclass) + `ProxyList`
- **Mode ABC**: 统一接口 `eval()` / `echo()`
- **Exit Code**: 所有模式统一返回 exit 0

## 子命令

- `eval`: 生成需要 `eval` 执行的命令（修改 shell 环境）
- `echo`: 生成直接输出的内容（配置、注释等）

## 支持的模式

| Mode | eval 输出 | echo 输出 | 说明 |
|------|-----------|-----------|------|
| shell | export/unset | 警告注释 | 标准 shell 环境变量 |
| npm | export/unset npm_config_* | 空 | npm 专用变量 |
| gradle | 空 | gradle.properties 格式 | Gradle 配置 |
| systemd | 空 | systemd override.conf 格式 | Systemd 服务配置 |

## 使用方法

### 基本用法

```bash
# 设置代理（自动检测 WSL2 IP）
px eval -a set

# 取消代理
px eval -a unset

# Gradle 配置
px echo -a set -m gradle

# npm 代理
px eval -a set -m npm

# Systemd 配置（默认 docker.service, system 模式）
px echo -a set -m systemd

# Systemd 自定义服务
px echo -a set -m systemd myapp user
```

### 参数

- `-a, --action`: `set` 或 `unset`
- `-m, --mode`: `shell`, `gradle`, `npm`, `systemd`（默认: shell）
- `-i, --ip`: 代理服务器 IP（未设置则自动检测 WSL2）
- `-p, --port`: 代理端口（默认: 7890）

## 配合 Shell 使用

```bash
# 加载包装函数
source px.sh

# 设置代理（自动检测 IP）
px

# 查看当前代理
pxshow

# 取消代理
unpx

# 其他模式
px -m gradle
px -m npm
px -m systemd myapp user
```

## 安装

```bash
# 1. 克隆或下载到 PATH 目录
cp px_real.py ~/.local/bin/px
cp px.sh ~/.config/shell/

# 2. 添加到你的 shell 配置
source ~/.config/shell/px.sh
```
"""

from __future__ import annotations

import argparse
import subprocess
import sys
from abc import ABC, abstractmethod
from dataclasses import dataclass
from typing import Iterable, Optional, Type


# =============================================================================
# Data Models
# =============================================================================

@dataclass(frozen=True)
class Proxy:
    """单个代理配置的数据模型"""
    name: str           # 如 'http_proxy'
    scheme: str         # 如 'http', 'https', 'socks5h'
    url_prefix: str     # 如 'http://', 'socks5h://'
    aliases: tuple[str, ...] = ()  # 大小写变体

    def full_url(self, host: str, port: str) -> str:
        return f"{self.url_prefix}{host}:{port}"

    def all_names(self) -> list[str]:
        return [self.name, *self.aliases]


@dataclass
class ProxyList:
    """代理列表，管理一组 Proxy 及其当前值"""
    proxies: list[Proxy]
    host: str = ""
    port: str = ""

    def __post_init__(self):
        self._by_scheme: dict[str, Proxy] = {p.scheme: p for p in self.proxies}

    def get(self, scheme: str) -> Optional[Proxy]:
        return self._by_scheme.get(scheme)

    def active(self, action: str) -> list[Proxy]:
        if action == "unset":
            return self.proxies
        if self.host and self.port:
            return self.proxies
        return []


DEFAULT_PROXIES = ProxyList([
    Proxy("http_proxy", "http", "http://", ("HTTP_PROXY",)),
    Proxy("https_proxy", "https", "http://", ("HTTPS_PROXY",)),
    Proxy("socks5h_proxy", "socks5h", "socks5h://", ("SOCKS5H_PROXY",)),
])


# =============================================================================
# Output Modes
# =============================================================================

class Mode(ABC):
    """输出模式的抽象基类"""
    NAME: str = ""
    SUPPORTED_SCHEMES: set[str] = set()

    def __init__(self, proxy_list: ProxyList, extra_args: list[str]):
        self.proxy_list = proxy_list
        self.extra_args = extra_args
        self._post_init()

    def _post_init(self):
        """子类可以重写此方法进行初始化"""
        pass

    def supports(self, proxy: Proxy) -> bool:
        return proxy.scheme in self.SUPPORTED_SCHEMES

    def active_proxies(self, action: str) -> list[Proxy]:
        return [p for p in self.proxy_list.active(action) if self.supports(p)]

    @abstractmethod
    def eval(self, action: str) -> list[str]:
        """生成需要 eval 执行的命令（修改 shell 环境），返回空列表表示无"""
        return []

    @abstractmethod
    def echo(self, action: str) -> list[str]:
        """生成直接输出的内容（配置、注释等）"""
        return []


class ShellMode(Mode):
    """Shell 环境变量模式"""
    NAME = "shell"
    SUPPORTED_SCHEMES = {"http", "https", "socks5h"}

    def eval(self, action: str) -> list[str]:
        lines = []
        for proxy in self.active_proxies(action):
            if action == "set":
                url = proxy.full_url(self.proxy_list.host, self.proxy_list.port)
                for name in proxy.all_names():
                    lines.append(f'export {name}="{url}"')
            else:
                for name in proxy.all_names():
                    lines.append(f"unset {name}")
        return lines

    def echo(self, action: str) -> list[str]:
        if action == "set" and not (self.proxy_list.host and self.proxy_list.port):
            return ["# 警告: 未配置代理服务器地址"]
        return []


class GradleMode(Mode):
    """Gradle 配置模式"""
    NAME = "gradle"
    SUPPORTED_SCHEMES = {"http", "https"}

    def eval(self, action: str) -> list[str]:
        return []

    def echo(self, action: str) -> list[str]:
        lines = []
        if action == "set":
            lines.append("# 将以下内容添加到 gradle.properties:")
            for proxy in self.active_proxies(action):
                lines.append(f"systemProp.{proxy.scheme}.proxyHost={self.proxy_list.host}")
                lines.append(f"systemProp.{proxy.scheme}.proxyPort={self.proxy_list.port}")
        return lines


class NpmMode(Mode):
    """NPM 环境变量模式"""
    NAME = "npm"
    SUPPORTED_SCHEMES = {"http", "https"}

    NPM_VARS = {"http": "npm_config_proxy", "https": "npm_config_https_proxy"}

    def eval(self, action: str) -> list[str]:
        lines = []
        for proxy in self.active_proxies(action):
            var = self.NPM_VARS.get(proxy.scheme)
            if not var:
                continue
            if action == "set":
                url = proxy.full_url(self.proxy_list.host, self.proxy_list.port)
                lines.append(f'export {var}="{url}"')
            else:
                lines.append(f"unset {var}")
        return lines

    def echo(self, action: str) -> list[str]:
        return []


class SystemdMode(Mode):
    """Systemd 服务配置模式"""
    NAME = "systemd"
    SUPPORTED_SCHEMES = {"http", "https", "socks5h"}

    def _post_init(self):
        # 从 extra_args 解析 service 和 mode
        self.service = ""
        self.mode = "system"  # 默认 system 模式

        for arg in self.extra_args:
            if "," in arg:
                parts = arg.split(",")
                self.service = parts[0]
                if len(parts) > 1:
                    self.mode = parts[1]
            elif arg in ("system", "user"):
                self.mode = arg
            else:
                self.service = arg

        if not self.service:
            self.service = "docker.service"

    def eval(self, action: str) -> list[str]:
        return []

    def echo(self, action: str) -> list[str]:
        lines = []

        if action == "set":
            if self.mode == "system":
                lines.append(f"# sudo systemctl daemon-reload")
                lines.append(f"# sudo systemctl restart {self.service}")

                for proxy in self.active_proxies(action):
                    url = proxy.full_url(self.proxy_list.host, self.proxy_list.port)
                    for name in proxy.all_names():
                        lines.append(f'# echo \'Environment="{name}={url}"\' | sudo tee -a /run/systemd/system/{self.service}.d/override.conf')
            else:
                # user mode
                lines.append(f"# mkdir -p $HOME/.config/systemd/user/{self.service}.d")
                lines.append(f"# 编辑: $HOME/.config/systemd/user/{self.service}.d/override.conf")
                lines.append("[Service]")

                for proxy in self.active_proxies(action):
                    url = proxy.full_url(self.proxy_list.host, self.proxy_list.port)
                    for name in proxy.all_names():
                        lines.append(f'Environment="{name}={url}"')
        else:
            # unset
            if self.mode == "system":
                for proxy in self.active_proxies(action):
                    for name in proxy.all_names():
                        lines.append(f'# sudo sed -i \'/Environment="{name}=/d\' /run/systemd/system/{self.service}.d/override.conf')

        return lines


# =============================================================================
# Registry
# =============================================================================

MODES: dict[str, Type[Mode]] = {
    m.NAME: m for m in [ShellMode, GradleMode, NpmMode, SystemdMode]
}


# =============================================================================
# WSL Detection
# =============================================================================

def detect_wsl_ip() -> Optional[str]:
    """检测 WSL2 宿主机 IP"""
    try:
        r = subprocess.run(["wslinfo", "--networking-mode"], capture_output=True, text=True, timeout=2)
        if r.returncode == 0 and r.stdout.strip() == "mirrored":
            return "localhost"
    except:
        pass

    try:
        r = subprocess.run(["uname", "-a"], capture_output=True, text=True, timeout=2)
        if "wsl2" in r.stdout.lower():
            r = subprocess.run(["ip", "route", "show"], capture_output=True, text=True, timeout=2)
            for line in r.stdout.split("\n"):
                if "default" in line:
                    parts = line.split()
                    for i, p in enumerate(parts):
                        if p == "via" and i + 1 < len(parts):
                            return parts[i + 1]
    except:
        pass
    return None


# =============================================================================
# CLI
# =============================================================================

def main():
    parser = argparse.ArgumentParser(description="代理环境变量设置工具")
    parser.add_argument("cmd", choices=["eval", "echo"], help="子命令: eval 或 echo")
    parser.add_argument("-a", "--action", choices=["set", "unset"], required=True)
    parser.add_argument("-m", "--mode", choices=list(MODES.keys()), default="shell")
    parser.add_argument("-i", "--ip", help="代理服务器 IP (未设置则自动检测)")
    parser.add_argument("-p", "--port", default="7890", help="代理端口 (默认: 7890)")

    args, extra = parser.parse_known_args()

    # IP 未设置则自动检测
    host = args.ip
    if not host:
        host = detect_wsl_ip()
        if not host:
            print("# 警告: 无法检测 WSL IP，使用 localhost", file=sys.stderr)
            host = "localhost"

    if args.action == "set" and not host:
        print("错误: 无法获取代理 IP", file=sys.stderr)
        sys.exit(1)

    # 准备代理列表
    proxies = ProxyList(list(DEFAULT_PROXIES.proxies), host, args.port)

    # 创建 Mode
    mode = MODES[args.mode](proxies, extra)

    # 执行子命令
    if args.cmd == "eval":
        lines = mode.eval(args.action)
    else:  # echo
        lines = mode.echo(args.action)

    for line in lines:
        print(line)


if __name__ == "__main__":
    main()
